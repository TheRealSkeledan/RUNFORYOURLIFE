<?xml version="1.0" encoding="UTF-8"?>
<spritesheet>
    <character name="MoneyIcon" spriteWidth="129" spriteHeight="90">
        <animations>

            <animation name="idle">
                <frame x="0" y="0"/>
            </animation>

            <animation name="click">
                <frame x ="0" y="0"/>
                <frame x="129" y="0"/>
                <frame x="256" y="0"/>

                <frame x="0" y="90"/>
                <frame x="129" y="90"/>
                <frame x="256" y="90"/>
                
                <frame x="0" y="180"/>
                <frame x="129" y="180"/>
                <frame x="256" y="180"/>
                
                <frame x="0" y="270"/>
                <frame x="129" y="270"/>
                <frame x="256" y="270"/>
            </animation>

        </animations>
    </character>
</spritesheet>